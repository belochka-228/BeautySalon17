<Page x:Class="BeautySalon17.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Стартовая страница">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
            <Button x:Name="BtnLogin" Content="Войти" Width="80" Height="30" Click="BtnLogin_Click" Visibility="Visible" />
            <Button x:Name="BtnAccount" Content="Аккаунт" Width="80" Height="30" Click="BtnAccount_Click" Visibility="Collapsed" Margin="10,0,0,0"/>
            <Button x:Name="BtnProducts" Content="Товары" Width="80" Height="30" Click="BtnProducts_Click" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- ПАНЕЛЬ ФИЛЬТРОВ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Услуга:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbFilterService" Width="180" Height="30" Margin="0,0,20,0"
              SelectionChanged="Filter_SelectionChanged"/>

            <TextBlock Text="Мастер:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbFilterMaster" Width="180" Height="30"
              SelectionChanged="Filter_SelectionChanged"/>

            <Button Content="Сбросить" Width="80" Height="30" Margin="20,0,0,0" Click="BtnResetFilters_Click"/>
        </StackPanel>
        
        <TextBlock Grid.Row="2" Text="Наши услуги" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="ServicesWrapPanel" Orientation="Horizontal" HorizontalAlignment="Center"
                       ItemWidth="220" ItemHeight="300"/>
        </ScrollViewer>
    </Grid>
</Page>
