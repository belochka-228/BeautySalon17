<Page x:Class="BeautySalon17.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Стартовая страница">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
            <Button x:Name="BtnLogin" Content="Войти" Width="80" Height="30" Click="BtnLogin_Click" Visibility="Visible" />
            <Button x:Name="BtnAccount" Content="Аккаунт" Width="80" Height="30" Click="BtnAccount_Click" Visibility="Collapsed" Margin="10,0,0,0"/>
            <Button x:Name="BtnProducts" Content="Товары" Width="80" Height="30" Click="BtnProducts_Click" Margin="10,0,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Добро пожаловать в салон красоты!" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Здесь будет список услуг / мастеров." FontSize="16" Margin="0,20,0,0"/>
            <!-- Здесь позже добавим фильтры, списки и прочее -->
        </StackPanel>
    </Grid>
        
        
</Page>
