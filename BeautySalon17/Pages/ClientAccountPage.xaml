<Page x:Class="BeautySalon17.Pages.ClientAccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientAccountPage">


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" Width="80" Height="30" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                Click="BtnBack_Click"/>

        <TabControl Grid.Row="1">
            <!-- Вкладка "Мои записи" (Страница записей) -->
            <TabItem Header="Мои записи">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтр по дате -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="DpFilterDate" Width="120" Height="30"/>
                        <Button Content="Показать" Width="80" Height="30" Margin="10,0,0,0" Click="BtnFilter_Click"/>
                        <Button Content="Сбросить" Width="80" Height="30" Margin="5,0,0,0" Click="BtnResetFilter_Click"/>
                    </StackPanel>

                    <!-- Таблица записей (только просмотр) -->
                    <DataGrid Grid.Row="1" x:Name="DgAppointments" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата и время" Binding="{Binding AppointmentDateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Услуга" Binding="{Binding Services.Name}" Width="150"/>
                            <DataGridTextColumn Header="Мастер" Binding="{Binding Users1.Surname}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Services.Price, StringFormat='{}{0:F2} руб.'}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка "Мои заказы" -->
            <TabItem Header="Мои заказы">
                <DataGrid x:Name="DgOrders" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
        </TabControl>
    </Grid>
</Page>