<Page x:Class="BeautySalon17.Pages.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ManagerPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Назад" Width="80" Height="30" 
                HorizontalAlignment="Left" Margin="0,0,0,10" Click="BtnBack_Click"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Записи">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Поиск клиента (ФИО/тел):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtClientSearch" Width="200" Height="30" VerticalContentAlignment="Center"/>
                        <Button Content="Найти" Width="60" Height="30" Margin="5,0,0,0" Click="BtnSearchClient_Click"/>
                        <Button Content="Сбросить" Width="70" Height="30" Margin="5,0,0,0" Click="BtnClearClientSearch_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="DgAppointments" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Дата/время" Binding="{Binding AppointmentDateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Услуга" Binding="{Binding Services.Name}" Width="150"/>
                            <DataGridTextColumn Header="Мастер" Binding="{Binding Users1.Surname}" Width="120"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding Users.Surname}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Создать запись" Width="120" Height="30" Click="BtnAddAppointment_Click"/>
                        <Button Content="Отменить запись" Width="120" Height="30" Margin="10,0,0,0" Click="BtnCancelAppointment_Click"/>
                        <Button Content="Перенести запись" Width="120" Height="30" Margin="10,0,0,0" Click="BtnMoveAppointment_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Заказы">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgOrders" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding Users.Surname}" Width="120"/>
                            <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                            <DataGridTextColumn Header="Дата выдачи" Binding="{Binding PickupDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                            <DataGridTextColumn Header="Оплата" Binding="{Binding PaymentMethod}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Отметить как выданный" Width="150" Height="30" Click="BtnCompleteOrder_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Товары">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgProducts" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:F2}'}" Width="80"/>
                            <DataGridTextColumn Header="Скидка %" Binding="{Binding Discount}" Width="70"/>
                            <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Добавить" Width="80" Height="30" Click="BtnAddProduct_Click"/>
                        <Button Content="Изменить" Width="80" Height="30" Margin="10,0,0,0" Click="BtnEditProduct_Click"/>
                        <Button Content="Заморозить" Width="90" Height="30" Margin="10,0,0,0" Click="BtnFreezeProduct_Click"/>
                        <Button Content="Разморозить" Width="90" Height="30" Margin="10,0,0,0" Click="BtnUnfreezeProduct_Click"/>
                        <Button Content="Скидка" Width="80" Height="30" Margin="10,0,0,0" Click="BtnDiscountProduct_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="Производители">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="370*"/>
                        <ColumnDefinition Width="31*"/>
                        <ColumnDefinition Width="353*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgManufacturers" AutoGenerateColumns="False" IsReadOnly="True" Grid.ColumnSpan="3">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" Grid.ColumnSpan="3">
                        <Button Content="Добавить" Width="80" Height="30" Click="BtnAddManufacturer_Click"/>
                        <Button Content="Изменить" Width="80" Height="30" Margin="10,0,0,0" Click="BtnEditManufacturer_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Типы товаров">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgProductTypes" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Добавить" Width="80" Height="30" Click="BtnAddProductType_Click"/>
                        <Button Content="Изменить" Width="80" Height="30" Margin="10,0,0,0" Click="BtnEditProductType_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Услуги">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgServices" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="80"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:F2}'}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Добавить" Width="80" Height="30" Click="BtnAddService_Click"/>
                        <Button Content="Изменить" Width="80" Height="30" Margin="10,0,0,0" Click="BtnEditService_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>