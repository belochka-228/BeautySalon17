<Page x:Class="BeautySalon17.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Корзина"
      Height="Auto" Width="Auto">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Назад" Width="80" Height="30" Click="BtnBack_Click"/>
            <TextBlock Text="Моя корзина" FontSize="20" FontWeight="Bold" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="CartItemsWrapPanel" Orientation="Horizontal" HorizontalAlignment="Left" ItemWidth="220" ItemHeight="350"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Итого: " FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTotalPrice" Text="0.00 руб." FontSize="18" FontWeight="Bold" 
                           Foreground="Green" VerticalAlignment="Center" Margin="5,0,20,0"/>
                <Button x:Name="BtnCheckout" Content="Оформить заказ" Width="150" Height="35" 
                        FontSize="14" Click="BtnCheckout_Click"/>
        </StackPanel>

    </Grid>
</Page>
