<Page x:Class="BeautySalon17.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BeautySalon17.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Назад" Width="80" Height="30" Click="BtnBack_Click"/>

            <TextBox x:Name="TxtSearch" Width="200" Height="30" Margin="30,0,0,0" VerticalContentAlignment="Center" />
            <Button Content="🔍" Width="40" Height="30" Click="BtnSearch_Click" Margin="5,0,0,0"/>
            <Button Content="Корзинка" Width="100" Height="30" HorizontalAlignment="Right" Click="BtnCart_Click" Margin="320,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Visible">
            <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbProductType" Width="120" Height="30" Margin="0,0,10,0" SelectionChanged="Filter_SelectionChanged"/>
            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbManufacturer" Width="120" Height="30"
              SelectionChanged="Filter_SelectionChanged"/>

            <TextBlock Text="Сортировка по рейтингу:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <ComboBox x:Name="CmbSorting" Width="120" Height="30" SelectedIndex="1" SelectionChanged="Sorting_SelectionChanged">
                <ComboBoxItem Content="возрастание" Tag="asc"/>
                <ComboBoxItem Content="убывание" Tag="desc"/>
            </ComboBox>
            
            <Button Content="Сбросить" Width="80" Height="30" Margin="20,0,0,0" Click="BtnResetFilters_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="ProductsWrapPanel" Orientation="Horizontal" HorizontalAlignment="Center" ItemWidth="220" ItemHeight="350"/>
        </ScrollViewer>
    </Grid>
</Page>
