<Window x:Class="BeautySalon17.Windows.ProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BeautySalon17.Windows"
        mc:Ignorable="d"
        Title="ProductDetailWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Картинка товара -->
        <Image x:Name="ProductImage" Grid.Column="0" Grid.RowSpan="7"
               Stretch="Uniform" Margin="0,0,20,0" Width="180" Height="180"
               VerticalAlignment="Top"/>

        <!-- Название -->
        <TextBlock Grid.Column="1" Grid.Row="0" x:Name="TxtName"
                   FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <!-- Рейтинг -->
        <TextBlock Grid.Column="1" Grid.Row="1" x:Name="TxtRating"
                   FontSize="14" Foreground="Goldenrod" Margin="0,0,0,5"/>

        <!-- Производитель -->
        <TextBlock Grid.Column="1" Grid.Row="2" x:Name="TxtManufacturer"
                   FontSize="14" Margin="0,0,0,5"/>

        <!-- Тип товара -->
        <TextBlock Grid.Column="1" Grid.Row="3" x:Name="TxtProductType"
                   FontSize="14" Margin="0,0,0,10"/>

        <!-- Цена -->
        <StackPanel Grid.Column="1" Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="TxtOldPrice" FontSize="14" Foreground="Gray"
                       TextDecorations="Strikethrough" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtPrice" FontSize="18" FontWeight="Bold" Foreground="Green"/>
        </StackPanel>

        <!-- Описание -->
        <TextBlock Grid.Column="1" Grid.Row="5" Text="Описание:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ScrollViewer Grid.Column="1" Grid.Row="6" VerticalScrollBarVisibility="Auto" MaxHeight="150">
            <TextBlock x:Name="TxtDescription" TextWrapping="Wrap" FontSize="14"/>
        </ScrollViewer>

        <!-- Кнопка закрыть -->
        <Button Grid.Column="1" Grid.Row="7" Content="Закрыть" Width="80" Height="30"
                HorizontalAlignment="Right" Margin="0,120,0,0" Click="BtnClose_Click"/>
    </Grid>
</Window>